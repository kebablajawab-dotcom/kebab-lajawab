rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: menuItems
    // Document ID: auto-generated
    // Fields:
    //   - id: string (optional)
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - category: string (required)
    //   - isVeg: boolean (optional)
    //   - image: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "kebablajawab@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidMenuItem(data) {
      return data.category is string && data.category.size() > 0 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 1000000;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================
    match /menuItems/{itemId} {
      // Anyone can read menu items
      allow read: if true;
      
      // Only admin can create, update, or delete
      allow create: if isAdmin() && isValidMenuItem(request.resource.data);
      allow update: if isAdmin() && isValidMenuItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      // Anyone can read gallery images
      allow read: if true;
      
      // Only admin can create, update, or delete
      allow create: if isAdmin() && 
                    request.resource.data.image is string && 
                    request.resource.data.image.size() < 1000000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      // Anyone can read settings (like the logo)
      allow read: if true;
      
      // Only admin can update settings
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
